{
  "name": "ucc-app-builder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Web-based tool for building Splunk apps using the UCC framework",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "build": "tsc -b && vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "preview": "vite preview",
    "start:server": "node dist-server/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --ext ts,tsx --fix",
    "eslint": "npm run lint",
    "eslint-fix": "npm run lint:fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css}\"",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "bench": "tsx eval/ucc-bench/runner.ts",
    "loop": "tsx tools/agent-loop.ts",
    "loop:demo": "tsx tools/agent-loop.ts",
    "loop:smoke": "tsx tools/agent-loop.ts --no-llm",
    "mcp:server": "tsx server/mcp/server.ts",
    "mcp:smoke": "tsx tools/mcp-smoke.ts",
    "ci": "npm run typecheck && npm run lint && npm run test:run && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monaco-editor/react": "^4.6.0",
    "@splunk/react-icons": "^5.7.0",
    "@splunk/react-ui": "^5.7.1",
    "@splunk/themes": "^1.4.1",
    "dotenv": "^17.4.2",
    "flexsearch": "^0.8.212",
    "jszip": "^3.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.1",
    "styled-components": "^5.3.11",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@types/styled-components": "^5.1.36",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^7.8.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.6.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.6",
    "express": "^4.19.2",
    "jsdom": "^24.0.0",
    "playwright": "^1.47.0",
    "prettier": "^3.2.5",
    "tsx": "^4.9.3",
    "typescript": "^5.4.5",
    "uuid": "^9.0.1",
    "vite": "^5.2.11",
    "vitest": "^1.6.0"
  }
}
