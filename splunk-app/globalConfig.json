{
    "meta": {
        "name": "ucc_app_builder",
        "restRoot": "ucc_app_builder",
        "displayName": "UCC App Builder",
        "version": "0.0.0+fa66415",
        "schemaVersion": "0.0.10",
        "checkForUpdates": false,
        "supportedThemes": [
            "light",
            "dark"
        ]
    },
    "pages": {
        "configuration": {
            "title": "Configuration",
            "description": "Configure the AI provider used by the App Builder advisor and AI chat.",
            "tabs": [
                {
                    "name": "ai_provider",
                    "title": "AI Provider",
                    "entity": [
                        {
                            "type": "singleSelect",
                            "label": "Provider",
                            "field": "provider",
                            "defaultValue": "openrouter",
                            "required": true,
                            "help": "LLM provider used by the agent.",
                            "options": {
                                "disableSearch": true,
                                "autoCompleteFields": [
                                    {
                                        "label": "OpenRouter",
                                        "value": "openrouter"
                                    },
                                    {
                                        "label": "OpenAI",
                                        "value": "openai"
                                    },
                                    {
                                        "label": "Anthropic",
                                        "value": "anthropic"
                                    },
                                    {
                                        "label": "Google",
                                        "value": "google"
                                    }
                                ]
                            }
                        },
                        {
                            "type": "text",
                            "label": "API key",
                            "field": "api_key",
                            "encrypted": true,
                            "required": false,
                            "help": "Stored encrypted in storage/passwords. Leave blank to keep the existing key.",
                            "validators": [
                                {
                                    "type": "string",
                                    "errorMsg": "Max 256 chars",
                                    "minLength": 0,
                                    "maxLength": 256
                                }
                            ]
                        },
                        {
                            "type": "text",
                            "label": "Base URL",
                            "field": "base_url",
                            "required": false,
                            "defaultValue": "https://openrouter.ai/api/v1",
                            "help": "OpenAI-compatible base URL (OpenRouter/OpenAI).",
                            "validators": [
                                {
                                    "type": "string",
                                    "errorMsg": "Max 255 chars",
                                    "minLength": 0,
                                    "maxLength": 255
                                }
                            ]
                        },
                        {
                            "type": "text",
                            "label": "Chat / agent model",
                            "field": "model",
                            "required": false,
                            "defaultValue": "anthropic/claude-sonnet-4.6",
                            "help": "Model for the AI assistant / build agent (reasoning + tool calls). Use a capable model, e.g. anthropic/claude-sonnet-4.6 (avoid Opus for cost/latency).",
                            "validators": [
                                {
                                    "type": "string",
                                    "errorMsg": "Max 128 chars",
                                    "minLength": 0,
                                    "maxLength": 128
                                }
                            ]
                        },
                        {
                            "type": "text",
                            "label": "Chat / agent temperature",
                            "field": "temperature",
                            "required": false,
                            "help": "Sampling temperature 0-2 for the chat/agent model (default 0.3).",
                            "validators": [
                                {
                                    "type": "string",
                                    "errorMsg": "Max 8 chars",
                                    "minLength": 0,
                                    "maxLength": 8
                                }
                            ],
                            "defaultValue": "0.3"
                        },
                        {
                            "type": "text",
                            "label": "Build-loop (AppInspect fixer) model",
                            "field": "build_model",
                            "required": false,
                            "defaultValue": "anthropic/claude-sonnet-4.6",
                            "help": "Model used by the self-correcting build loop to fix AppInspect findings. Needs solid JSON/code ability.",
                            "validators": [
                                {
                                    "type": "string",
                                    "errorMsg": "Max 128 chars",
                                    "minLength": 0,
                                    "maxLength": 128
                                }
                            ]
                        },
                        {
                            "type": "text",
                            "label": "Build-loop temperature",
                            "field": "build_temperature",
                            "required": false,
                            "help": "Sampling temperature for the build-loop fixer (default 0.1).",
                            "validators": [
                                {
                                    "type": "string",
                                    "errorMsg": "Max 8 chars",
                                    "minLength": 0,
                                    "maxLength": 8
                                }
                            ],
                            "defaultValue": "0.1"
                        },
                        {
                            "type": "text",
                            "label": "Inline-completion model",
                            "field": "completion_model",
                            "required": false,
                            "defaultValue": "anthropic/claude-haiku-4.5",
                            "help": "Fast, cheap model for editor ghost-text completion (fires on every typing pause).",
                            "validators": [
                                {
                                    "type": "string",
                                    "errorMsg": "Max 128 chars",
                                    "minLength": 0,
                                    "maxLength": 128
                                }
                            ]
                        },
                        {
                            "type": "text",
                            "label": "Inline-completion temperature",
                            "field": "completion_temperature",
                            "required": false,
                            "help": "Sampling temperature for inline completion (default 0.1).",
                            "validators": [
                                {
                                    "type": "string",
                                    "errorMsg": "Max 8 chars",
                                    "minLength": 0,
                                    "maxLength": 8
                                }
                            ],
                            "defaultValue": "0.1"
                        },
                        {
                            "type": "text",
                            "label": "Max agent iterations",
                            "field": "max_iterations",
                            "required": false,
                            "defaultValue": "40",
                            "help": "Planner/executor turns before the agent stops.",
                            "validators": [
                                {
                                    "type": "string",
                                    "errorMsg": "Max 4 chars",
                                    "minLength": 0,
                                    "maxLength": 4
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    }
}
