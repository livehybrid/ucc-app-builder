{
    "compilerOptions": {
        "target": "es2020",
        "module": "esnext",
        "moduleResolution": "node",
        "jsx": "react",
        "allowJs": true,
        "checkJs": false,
        "noEmit": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "baseUrl": "."
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "stage", "build", "dist"]
}
